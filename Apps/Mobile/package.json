{
  "name": "@flora/mobile",
  "main": "./index.ts",
  "version": "0.2.0-alpha",
  "private": true,
  "scripts": {
    "dev": "expo start --dev-client",
    "dev:usb": "expo start --dev-client --port 8081",
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "android:usb": "adb reverse tcp:8081 tcp:8081 && adb reverse tcp:5284 tcp:5284 && expo start --dev-client",
    "debug:usb": "powershell -NoProfile -ExecutionPolicy Bypass -File ../../Scripts/mobile-debug-android.ps1",
    "install:android:debug": "powershell -NoProfile -ExecutionPolicy Bypass -File ../../Scripts/mobile-install-debug-android.ps1",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "postinstall": "node ../../Scripts/patch-ffmpeg-kit.mjs",
    "assets:icons": "node ../../Scripts/render-flora-mobile-assets.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "prebuild:android": "expo prebuild --platform android --clean",
    "prebuild:ios": "expo prebuild --platform ios --clean",
    "build:android:release": "powershell -NoProfile -ExecutionPolicy Bypass -File ../../Scripts/mobile-release-android.ps1",
    "install:android:release": "powershell -NoProfile -ExecutionPolicy Bypass -File ../../Scripts/mobile-install-release-android.ps1",
    "build:ios:production": "eas build --platform ios --profile production --non-interactive",
    "build:android:production": "eas build --platform android --profile production --non-interactive",
    "build:production": "eas build --platform all --profile production --non-interactive"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@flora/client-core": "*",
    "@react-native-community/netinfo": "11.4.1",
    "@react-navigation/native": "^7.1.8",
    "@sentry/react-native": "^6.22.0",
    "@shopify/flash-list": "2.0.2",
    "@tanstack/react-query": "^5.90.2",
    "expo": "~56.0.11",
    "expo-audio": "~56.0.12",
    "expo-constants": "~56.0.18",
    "expo-dev-client": "~56.0.10",
    "expo-device": "^56.0.4",
    "expo-document-picker": "^56.0.4",
    "expo-file-system": "~56.0.8",
    "expo-font": "~56.0.6",
    "expo-image": "~56.0.11",
    "expo-image-picker": "~56.0.17",
    "expo-linking": "~56.0.14",
    "expo-notifications": "^56.0.18",
    "expo-router": "~56.2.10",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-video": "~56.1.3",
    "ffmpeg-kit-react-native": "^6.0.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-compressor": "^1.13.0",
    "react-native-libsodium": "^1.4.0",
    "react-native-mmkv": "^3.3.0",
    "react-native-quick-crypto": "^0.7.17",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "eas-cli": "^16.28.0",
    "eslint": "^9.39.1",
    "eslint-config-expo": "~10.0.0",
    "typescript": "~6.0.3"
  }
}
