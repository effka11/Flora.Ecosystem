# Copy to Scripts/broadcast.env (gitignored). Used by broadcast-app-update.ps1 with -Production.
#
# FLORA_API_URL must match release APK (Apps/Mobile/.env → EXPO_PUBLIC_API_URL).
# FLORA_ADMIN_BROADCAST_TOKEN must match prod API:
#   Flora:AdminBroadcastToken in appsettings.Production.json, or on VPS:
#   Flora__AdminBroadcastToken in /etc/flora-ecosystem/flora-api.env
#
FLORA_API_URL=https://origin.flora-s.net
FLORA_ADMIN_BROADCAST_TOKEN=
