{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "FloraDatabase": "Host=localhost;Port=5432;Database=flora_social;Username=flora;Password=change-me;Include Error Detail=true;Search Path=flora_core"
  },
  "Jwt": {
    "Issuer": "Flora.Auth",
    "Audience": "Flora.Ecosystem",
    "Secret": "",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 7
  },
  "FeedRecommendation": {
    "EnableCache": true,
    "CacheSeconds": 120,
    "MaxCandidates": 2000,
    "FollowingPostsDays": 30
  },
  "FiraFeed": {
    "AlphaPhase0": 0.0,
    "BetaPhase0": 0.70,
    "GammaPhase0": 0.30,
    "DecayLambda": 0.05,
    "AuthorAffinityScale": 5.0,
    "AffinityThreshold": 0.0,
    "SocialRepostThreshold": 1,
    "RepostWeight": 1.5,
    "RepostCap": 3.0,
    "MaxConsecutiveSameAuthor": 2,
    "ExplorationQuota": 0.15,
    "MaxCandidates": 1000,
    "FollowingWindowDays": 7,
    "TrendingWindowDays": 2,
    "InteractionHistoryDays": 90,
    "EnableCache": true,
    "CacheTtlSeconds": 120
  },
  "UserRecommendation": {
    "WeightFollowers": 2.0,
    "WeightSocial": 4.0,
    "WeightRecency": 1.0,
    "RecencyBoostDays": 30,
    "CacheTtlSeconds": 300
  },
  "CommunityRecommendation": {
    "ActivityDays": 14,
    "NewCommunityBoostDays": 14,
    "WeightMembers": 2.0,
    "WeightActivity": 3.0,
    "WeightSocial": 4.0,
    "WeightRecency": 1.5,
    "CacheTtlSeconds": 600
  },
  "Media": {
    "FfmpegPath": "ffmpeg",
    "FfprobePath": null
  },
  "Smtp": {
    "Host": "",
    "Port": 587,
    "Username": "",
    "Password": "",
    "FromEmail": "",
    "FromName": "Flora",
    "EnableSsl": true
  },
  "FloraWeb": {
    "CorsOrigins": [ "http://localhost:3000" ]
  }
}
