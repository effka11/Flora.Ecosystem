{
  "name": "@flora/client-core",
  "version": "0.3.0-alpha",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./contracts": {
      "types": "./src/contracts/index.ts",
      "import": "./src/contracts/index.ts",
      "default": "./src/contracts/index.ts"
    },
    "./api": {
      "types": "./src/api/index.ts",
      "import": "./src/api/index.ts",
      "default": "./src/api/index.ts"
    },
    "./auth": {
      "types": "./src/auth/index.ts",
      "import": "./src/auth/index.ts",
      "default": "./src/auth/index.ts"
    },
    "./fscp": {
      "types": "./src/fscp/index.ts",
      "import": "./src/fscp/index.ts",
      "default": "./src/fscp/index.ts"
    },
    "./storage": {
      "types": "./src/storage/index.ts",
      "import": "./src/storage/index.ts",
      "default": "./src/storage/index.ts"
    },
    "./telemetry": {
      "types": "./src/telemetry/index.ts",
      "import": "./src/telemetry/index.ts",
      "default": "./src/telemetry/index.ts"
    },
    "./signals": {
      "types": "./src/signals/index.ts",
      "import": "./src/signals/index.ts",
      "default": "./src/signals/index.ts"
    },
    "./crypto": {
      "types": "./src/crypto/aesGcm.ts",
      "import": "./src/crypto/aesGcm.ts",
      "default": "./src/crypto/aesGcm.ts"
    },
    "./display": {
      "types": "./src/display/index.ts",
      "import": "./src/display/index.ts",
      "default": "./src/display/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@noble/curves": "^1.9.7",
    "@noble/hashes": "^2.2.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "libsodium": "^0.7.15",
    "libsodium-wrappers": "^0.7.15",
    "libsodium-wrappers-sumo": "^0.8.4",
    "typescript": "^5.8.2",
    "vitest": "^3.2.4"
  }
}
