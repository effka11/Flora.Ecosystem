{
  "expo": {
    "name": "Flora",
    "slug": "flora-mobile",
    "version": "0.1.0-alpha.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "flora",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "social.flora.mobile",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Flora использует микрофон для записи голосовых сообщений."
      }
    },
    "android": {
      "package": "social.flora.mobile",
      "versionCode": 1,
      "googleServicesFile": "./google-services.json",
      "backgroundColor": "#0c0c0c",
      "navigationBar": {
        "backgroundColor": "#0c0c0c"
      },
      "adaptiveIcon": {
        "backgroundColor": "#2c3527",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "flora.social",
              "pathPrefix": "/profile"
            },
            {
              "scheme": "https",
              "host": "flora.social",
              "pathPrefix": "/post"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#0c0c0c",
          "imageWidth": 200,
          "dark": {
            "backgroundColor": "#0c0c0c"
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-audio",
        {
          "microphonePermission": "Flora использует микрофон для записи голосовых сообщений.",
          "recordAudioAndroid": true
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/android-icon-monochrome.png",
          "color": "#2c3527",
          "defaultChannel": "messages"
        }
      ],
      [
        "./plugins/withFfmpegKit",
        {
          "iosUrl": "https://github.com/NooruddinLakhani/ffmpeg-kit-ios-full-gpl/archive/refs/tags/latest.zip",
          "androidUrl": "https://github.com/NooruddinLakhani/ffmpeg-kit-full-gpl/releases/download/v1.0.0/ffmpeg-kit-full-gpl.aar"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "00000000-0000-0000-0000-000000000001"
      }
    }
  }
}
